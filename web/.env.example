DATABASE_URL="postgresql://plumber:plumber@localhost:5432/plumber_app"
SESSION_SECRET="replace-with-a-long-random-string"
# 32-byte key (hex: 64 chars, or base64) for encrypting stored secrets at rest.
# Generate: openssl rand -hex 32   (or)   openssl rand -base64 32
# If unset, a dev key is derived from SESSION_SECRET — DO NOT rely on that in prod.
APP_ENCRYPTION_KEY=""
